-- WARP GLOVE TAB SCRIPT
local Stewfield = getgenv().sbstew_Stewfield
local Window = getgenv().sbstew_Window
local Places = getgenv().sbstew_Places

-- Load Engine if not already present
if not getgenv().BotEngine then
    loadstring(game:HttpGet("https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Engine"))()
end
local Engine = getgenv().BotEngine

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local TargetGlove = "Swapper"
local LockedTarget = nil
local SlapCooldown = false
local InfiniteMode = false

-- Remote/Animation references from Engine
local SlapRemote = ReplicatedStorage.HitSwapper
local AbilityRemote = ReplicatedStorage:WaitForChild("SLOC")
local SlapAnimation = ReplicatedStorage.Slap

local WarpTab = Window:CreateTab("Warp Glove", "rss")
WarpTab:CreateLabel("Warp Glove Obtainment")

local function PerformWarpLogic()
    local Character = LocalPlayer.Character
    local Humanoid = Character and Character:FindFirstChild("Humanoid")
    if not Character or not Humanoid then return end

    getgenv().BSF = true
    
    task.spawn(function()
        while getgenv().BSF do
            if Engine.IsInLobby(Character) then
                -- Engine Lobby Logic
                local _, currentGlove = Engine.GetStats()
                if currentGlove ~= TargetGlove then
                    Engine.EquipGlove(TargetGlove)
                else
                    Engine.WalkToPortal()
                end
            else
                local TargetPlayer, Distance = Engine.GetValidTarget(Humanoid, 80)

                if TargetPlayer and TargetPlayer.Character then
                    local TargetRoot = TargetPlayer.Character:FindFirstChildWhichIsA("Humanoid").RootPart
                    if Humanoid.Health > 0 and TargetRoot then
                        Humanoid:MoveTo(TargetRoot.Position)

                        -- Slap Logic
                        if Distance < 15 and not SlapCooldown then
                            SlapCooldown = true
                            local AnimTrack = Humanoid:FindFirstChild("Animator"):LoadAnimation(SlapAnimation)
                            if AnimTrack then AnimTrack:Play() end
                            SlapRemote:FireServer(TargetRoot)
                            task.delay(0.6, function() SlapCooldown = false end)
                        end
                    end
                else
                    getgenv().BSF = false
                    task.spawn(function()
                        task.wait(0.35)
                        AbilityRemote:FireServer()
                        task.wait(1)
                        if ReplicatedStorage:FindFirstChild("SelfDestruct") then
                            ReplicatedStorage.SelfDestruct:FireServer()
                        end
                    end)
                end
            end
            RunService.RenderStepped:Wait()
        end
    end)
end

-- Character Connection for Infinite Mode
LocalPlayer.CharacterAdded:Connect(function(char)
    if InfiniteMode then
        task.wait(1)
        PerformWarpLogic()
    end
end)

WarpTab:CreateButton({
    Name = "Equip Swapper glove",
    Callback = function()
        if Engine.IsInLobby() then
            local slaps = Engine.GetStats()
            if slaps >= 350 then
                Engine.EquipGlove("Swapper")
            else
                Stewfield:Notify({
                    Title = "Insufficient Slaps",
                    Content = "You need 350 slaps to equip Swapper!",
                    Duration = 5,
                    Image = "lock"
                })
            end
        else
            Stewfield:Notify({
                Title = "Error",
                Content = "Make sure you're in the lobby.",
                Duration = 5,
                Image = "circle-alert"
            })
        end
    end,
})

WarpTab:CreateButton({
    Name = "Get Warp",
    Callback = function()
        local _, currentGlove = Engine.GetStats()
        if currentGlove == "Swapper" then
            PerformWarpLogic()
        else
            Stewfield:Notify({
                Title = "Glove Required",
                Content = "You must have the Swapper glove equipped first!",
                Duration = 5,
                Image = "lock"
            })
        end
    end,
})

WarpTab:CreateToggle({
    Name = "Retry",
    CurrentValue = false,
    Flag = "AutoWarp_Flag",
    Callback = function(Value)
        InfiniteMode = Value
    end,
})

WarpTab:CreateParagraph({
    Title = "Instructions",
    Content = "1. Press 'Equip Swapper'\n2. Press 'Get Warp' to start the bot logic.\n3. If 'Retry' is enabled, the bot will automatically restart.\n4. If 'Retry' is disabled, the bot will stop after the first attempt or reset."
})

return WarpTab
