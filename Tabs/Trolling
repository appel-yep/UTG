local Stewfield = getgenv().sbstew_Stewfield
local Window = getgenv().sbstew_Window

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local MarketPlaceService = game:GetService("MarketplaceService")

-- Configuration & State
local TrollCount = 1
local TrollingActive = false
local SelectedTroll = "void"
local SelectedTarget = "Random"
local ResetRemote = ReplicatedStorage:WaitForChild("SelfDestruct", 5) or ReplicatedStorage:WaitForChild("Reset", 5)
local SLOC_Remote = ReplicatedStorage:WaitForChild("SLOC", 5)

-- Void Coordinates
local VoidPositions = {
    Vector3.new(101, -107, 24),
    Vector3.new(-3.6, -107, 115.4),
    Vector3.new(-116.3, -107, 0.5),
    Vector3.new(-4.7, -107, -111.1)
}

-- Remote Protection Hook
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    if TrollingActive and self == SLOC_Remote and (method == "FireServer" or method == "fireServer") then
        if not checkcaller() then
            return nil
        end
    end
    return oldNamecall(self, ...)
end)

-- Helper logic for Stats
local function getStats()
    local stats = LocalPlayer:FindFirstChild("leaderstats")
    local slaps = (stats and stats:FindFirstChild("Slaps")) and stats.Slaps.Value or 0
    local currentGlove = (stats and stats:FindFirstChild("Glove")) and stats.Glove.Value or "None"
    return slaps, currentGlove
end

-- Helper logic to find the closest valid player name
local function getClosestPlayerName()
    local closestName = nil
    local shortestDist = math.huge
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    
    if not myRoot then return nil end

    for _, p in pairs(Players:GetPlayers()) do
        local char = p.Character
        if p ~= LocalPlayer and char and char:FindFirstChild("HumanoidRootPart") then
            -- Rock Logic Check
            local isRock = char:FindFirstChild("rock") or char:FindFirstChild("megarock")
            local isRagdolled = char:FindFirstChild("FakePart Right Arm")
            local isInLobby = char:FindFirstChild("InLobby")
            
            if not isRock and not isRagdolled and not isInLobby then
                local dist = (myRoot.Position - char.HumanoidRootPart.Position).Magnitude
                if dist < shortestDist then
                    shortestDist = dist
                    closestName = p.Name
                end
            end
        end
    end
    return closestName
end

-- Tab Creation
local TrollingTab = Window:CreateTab("Trolling", "laugh")

local TrollingToggle
local TargetDropdown

-- Dropdown Refresh Logic
local function RefreshPlayerList()
    local playerNames = {"Random"}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            table.insert(playerNames, p.Name)
        end
    end
    if TargetDropdown then
        TargetDropdown:Refresh(playerNames)
    end
end

Players.PlayerAdded:Connect(RefreshPlayerList)
Players.PlayerRemoving:Connect(RefreshPlayerList)

