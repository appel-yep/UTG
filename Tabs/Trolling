-- Main Logic Function
local function RunTrollLogic()
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChild("Humanoid")
    local rootPart = char and char:FindFirstChild("HumanoidRootPart")
    if not char or not hum or not rootPart then return end
    
    local _, glove = getStats()
    local LobbyPath = Workspace:FindFirstChild(LocalPlayer.Name) and Workspace[LocalPlayer.Name]:FindFirstChild("InLobby")

    if LobbyPath then
        TrollingActive = false
        if TrollingToggle then TrollingToggle:Set(false) end
        Stewfield:Notify({Title = "Arena Required", Content = "Please enter the arena!", Duration = 5, Image = "circle-alert"})
        return
    end
    
    if glove ~= "Swapper" then
        TrollingActive = false
        if TrollingToggle then TrollingToggle:Set(false) end
        Stewfield:Notify({Title = "Glove Required", Content = "Equip Swapper!", Duration = 5, Image = "circle-alert"})
        return
    end

    task.wait(3)

    -- Creation of Void Parts
    local voidParts = {}
    if SelectedTroll == "void" then
        for i, pos in ipairs(VoidPositions) do
            local p = Instance.new("Part")
            p.Name = "S5Void_" .. i
            p.Anchored = true
            p.CanCollide = true
            p.Transparency = 0.5
            p.Position = pos
            p.Size = Vector3.new(24, 3, 24)
            p.Parent = Workspace
            table.insert(voidParts, p)
        end
    end

    for i = 1, TrollCount do
        if not TrollingActive then break end

        -- Step A: Positioning
        if SelectedTroll == "cube of death" then
            local cubePath = Workspace.Arena.CubeOfDeathArea:FindFirstChild("the cube of death(i heard it kills)")
            if cubePath then
                cubePath.CanTouch = false
                if cubePath:FindFirstChild("Part") then cubePath.Part.CanTouch = false end
                rootPart.CFrame = cubePath.CFrame * CFrame.new(0, 5, 0)
            end
        elseif SelectedTroll == "void" then
            local targetPos = VoidPositions[1]
            
            if SelectedTarget == "Random" then
                targetPos = VoidPositions[math.random(1, #VoidPositions)]
            else
                local tPlayer = Players:FindFirstChild(SelectedTarget)
                if tPlayer and tPlayer.Character and tPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    local tRootPos = tPlayer.Character.HumanoidRootPart.Position
                    local closestVoid = VoidPositions[1]
                    local minVDist = math.huge
                    for _, vPos in ipairs(VoidPositions) do
                        local vDist = (tRootPos - vPos).Magnitude
                        if vDist < minVDist then
                            minVDist = vDist
                            closestVoid = vPos
                        end
                    end
                    targetPos = closestVoid
                end
            end
            rootPart.CFrame = CFrame.new(targetPos) * CFrame.new(0, 5, 0)
        end

        -- Step B: Wait for valid target
        if SelectedTarget ~= "Random" then
            Stewfield:Notify({Title = "Targeting", Content = "Waiting for " .. SelectedTarget .. " (No Rocks allowed)", Duration = 999, Image = "clock"})
            repeat
                task.wait(0.1)
                if not Players:FindFirstChild(SelectedTarget) or not TrollingActive then break end
            until getClosestPlayerName() == SelectedTarget
        end

        -- Step C: Trigger Swap
        task.wait(0.3)
        if SLOC_Remote and TrollingActive then
            SLOC_Remote:FireServer()
        end

        if i < TrollCount then task.wait(7) end
    end
    
    for _, v in ipairs(voidParts) do v:Destroy() end
    
    if TrollingActive then
        TrollingActive = false
        if TrollingToggle then TrollingToggle:Set(false) end
        if ResetRemote then ResetRemote:FireServer() else if LocalPlayer.Character.Humanoid then LocalPlayer.Character.Humanoid.Health = 0 end end
    end
end

