local startTime = nil
local BeginButton

BeginButton = VoodooTab:CreateButton({
    Name = "Begin",
    Callback = function()
        local _, currentGlove = Utils.GetStats()

        if not Utils.IsInLobby() then
            if currentGlove == "Ghost" then
                startTime = tick()

                local args = {}
                game:GetService("ReplicatedStorage"):WaitForChild("Ghostinvisibilityactivated"):FireServer(unpack(args))

                Stewfield:Notify({
                    Title = "Ability Activated",
                    Content = "The 1 hour timer starts now.",
                    Duration = 4,
                    Image = "check"
                })

                if BeginButton then
                    BeginButton:Destroy()
                end
            else
                Stewfield:Notify({
                    Title = "Wrong Glove",
                    Content = "You must have Ghost equipped!",
                    Duration = 5,
                    Image = "circle-alert"
                })
            end
        else
            Stewfield:Notify({
                Title = "Error",
                Content = "You must be in the Arena to begin!",
                Duration = 5,
                Image = "circle-alert"
            })
        end
    end,
})

local AntiAFKConnection
local AntiAFKToggle = VoodooTab:CreateToggle({
    Name = "Anti-Disconnect",
    CurrentValue = false,
    Flag = "AntiAFK_Flag",
    Callback = function(Value)
        if Value then
            local VirtualUser = game:GetService("VirtualUser")
            AntiAFKConnection = LocalPlayer.Idled:Connect(function()
                VirtualUser:CaptureController()
                VirtualUser:ClickButton2(Vector2.new())
            end)
        else
            if AntiAFKConnection then
                AntiAFKConnection:Disconnect()
                AntiAFKConnection = nil
            end
        end
    end,
})

