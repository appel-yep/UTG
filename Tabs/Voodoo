})

local function Create(InstanceType, Properties, Children)
    local obj = Instance.new(InstanceType)
    for prop, val in pairs(Properties) do
        obj[prop] = val
    end
    if Children then
        for _, child in ipairs(Children) do
            child.Parent = obj
        end
    end
    obj.Parent = Properties.Parent
    return obj
end

