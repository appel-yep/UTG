-- PLATE GLOVE TAB SCRIPT
local Stewfield = getgenv().sbstew_Stewfield
local Window = getgenv().sbstew_Window
local Places = getgenv().sbstew_Places

-- Create Tab
local PlateTab = Window:CreateTab("Plate Glove", "disc")
PlateTab:CreateLabel("Plate Glove Buttons")

-- 1. Go to Plate Place Button
PlateTab:CreateButton({
    Name = "Go to plate place",
    Callback = function()
        if Places["Lobby3"] then    
            getgenv().PlateSlapActive = false
            task.wait(0.1)

            local character = game.Players.LocalPlayer.Character
            local hum = character:FindFirstChildOfClass("Humanoid")
            local rootPart = character:FindFirstChild("HumanoidRootPart")
            local portal = workspace.Lobby.Teleport1
            local targetPlate = workspace.Arena.Plate
            local targetText = workspace.Arena.Plate.Sign.Text

            -- 1. Walk to Portal
            if hum and portal then
                hum:MoveTo(portal.Position)
                local entered = false
                local connection
                connection = portal.Touched:Connect(function(hit)
                    if hit:IsDescendantOf(character) then
                        entered = true
                        connection:Disconnect()
                    end
                end)
                
                local start = tick()
                repeat task.wait() until entered or (tick() - start > 5)
                task.wait(0.5) 
            end

            -- 2. Tp to plate
            if hum and rootPart and targetPlate and targetText then
                hum.Jump = true 
                task.wait(0.1)
                
                local platePos = targetPlate.Position
                local signPos = targetText.Position
                
                rootPart.CFrame = CFrame.lookAt(
                    Vector3.new(platePos.X, platePos.Y + 3, platePos.Z), 
                    Vector3.new(signPos.X, platePos.Y + 3, signPos.Z)
                )
                task.wait(0.2)
            end

            -- 3. Auto Slap
            getgenv().PlateSlapActive = true
            Stewfield:Notify({
                Title = "Auto Slap",
                Content = "Started slapping (Invisible Reach Active)",
                Duration = 3,
                Image = "info",
            })

            task.spawn(function()
                while getgenv().PlateSlapActive do
                    local char = game.Players.LocalPlayer.Character
                    local root = char and char:FindFirstChild("HumanoidRootPart")
                    local tool = char and char:FindFirstChildOfClass("Tool")
                    
                    -- Check if player died to stop loop
                    if not char or not char:FindFirstChild("Humanoid") or char.Humanoid.Health <= 0 then
                        getgenv().PlateSlapActive = false
                        break
                    end

                    -- Reach
                    if tool then
                        local handle = tool:FindFirstChild("Handle") or tool:FindFirstChildOfClass("Part")
                        if handle then
                            handle.Size = Vector3.new(15, 15, 15)
                            handle.CanCollide = false
                            handle.Transparency = 1
                        end
                        tool:Activate()
                    end

                    -- Constant Lock
                    if root and targetText then
                        local signPos = targetText.Position
                        root.CFrame = CFrame.lookAt(
                            root.Position, 
                            Vector3.new(signPos.X, root.Position.Y, signPos.Z)
                        )
                    end
                    task.wait(0.1)
                end
            end)
        else
            Stewfield:Notify({
                Title = "Wrong Game",
                Content = "You must be in the Slap Battles Lobby to use this.",
                Duration = 4,
                Image = "circle-alert",
            })
        end
    end,
})

-- 2. Delete Obstacles Button
PlateTab:CreateButton({
    Name = "Delete all obstacles",
    Callback = function()
        if Places["Plate"] then
            if workspace:FindFirstChild("Obstacles") then 
                workspace.Obstacles:Destroy() 
                Stewfield:Notify({
                    Title = "Success",
                    Content = "All obstacles removed!",
                    Duration = 3,
                    Image = "check",
                })
            end
            
            task.spawn(function()
                local connection
                connection = workspace:GetAttributeChangedSignal("Completed"):Connect(function()
                    if workspace:GetAttribute("Completed") == true then
                        Stewfield:Notify({
                            Title = "Notification",
                            Content = "Task finished!",
                            Duration = 5,
                            Image = "check",
                        })
                        connection:Disconnect()
                    end
                end)
            end)
        else
            Stewfield:Notify({
                Title = "Wrong Game",
                Content = "You must be in the Plate obtainment place to use this.",
                Duration = 4,
                Image = "circle-alert",
            })
        end
    end,
})

-- 3. Go to Glove Button
PlateTab:CreateButton({
    Name = "Go to glove",
    Callback = function()
        if Places["Plate"] then
            local character = game.Players.LocalPlayer.Character
            local target = workspace:FindFirstChild("Glove Model") and workspace["Glove Model"]:FindFirstChild("Hand")
            
            if target then
                local rootPart = character:FindFirstChild("HumanoidRootPart")
                local hum = character:FindFirstChildOfClass("Humanoid")
                
                if rootPart and hum then
                    hum:ChangeState(Enum.HumanoidStateType.Jumping)
                    task.wait(0.05)
                    rootPart.CFrame = target.CFrame
                end
            else
                Stewfield:Notify({
                    Title = "Not Spawned",
                    Content = "The glove has not spawned yet!",
                    Duration = 4,
                    Image = "circle-alert",
                })
            end
        else
            Stewfield:Notify({
                Title = "Wrong Game",
                Content = "You must be in the Plate place to use this.",
                Duration = 4,
                Image = "circle-alert",
            })
        end
    end,
})

PlateTab:CreateParagraph({
    Title = "Instructions",
    Content = "1. Use 'Go to plate place' while in the Lobby.\n2. Once in the Plate place, use 'Delete all obstacles'.\n3. Wait for the 'Done' notification.\n4. Click 'Go to glove' to claim the badge."
})

return PlateTab
