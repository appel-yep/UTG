-- ADMIN GLOVE SCRIPT
local Rayfield = getgenv().sbstew_Rayfield
local Window = getgenv().sbstem_Window

local startTime = nil

local function isAtLobby()
    local id = game.PlaceId
    return (id == 6403373529 or id == 9015014224 or id == 11520107397)
end

-- Create Tab
local AdminTab = Window:CreateTab("Admin Glove", "shield-check")
AdminTab:CreateLabel("Admin Glove Buttons")

-- 1. Application Button TP
AdminTab:CreateButton({
    Name = "Teleport to application button",
    Callback = function()
        if isAtLobby() then
            game.ReplicatedStorage.Assets.Retro.Parent = game.Workspace
            task.wait(0.1)
            local root = game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if root then
                root.CFrame = CFrame.new(-16976, 801, 4907)
            end
        else
            Rayfield:Notify({
                Title = "Wrong Game", 
                Content = "You must be in the Slap Battles Lobby to use this.", 
                Duration = 4,
                Image = "circle-alert"
            })
        end
    end,
})

-- 2. Final Room TP
AdminTab:CreateButton({
    Name = "Tp to the final room",
    Callback = function()
        if game.PlaceId == 16034567693 then
            local root = game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if root then
                root.CFrame = CFrame.new(499.860291, 77.2709045, 60.5982056)
                startTime = tick() -- Starts the 1-hour timer
            end
        else
            Rayfield:Notify({
                Title = "Wrong Game", 
                Content = "You must be in the Admin Application place to use this.", 
                Duration = 4,
                Image = "circle-alert"
            })
        end
    end,
})

-- 3. Anti-AFK Toggle
local AntiAFKConnection
local AntiAFKToggle = AdminTab:CreateToggle({
    Name = "Anti AFK",
    CurrentValue = false,
    Flag = "AntiAFK_Flag",
    Callback = function(Value)
        if Value then
            -- Enable Anti-AFK
            local VirtualUser = game:GetService("VirtualUser")
            AntiAFKConnection = game.Players.LocalPlayer.Idled:Connect(function()
                VirtualUser:CaptureController()
                VirtualUser:ClickButton2(Vector2.new())
            end)
        else
            -- Disable Anti-AFK
            if AntiAFKConnection then
                AntiAFKConnection:Disconnect()
                AntiAFKConnection = nil
            end
        end
    end,
})

-- Ensure it starts off
AntiAFKToggle:Set(false)

AdminTab:CreateParagraph({
    Title = "Instructions",
    Content = "1. In the Lobby, use 'Teleport to application button'.\n2. Once in the Application place, use 'Tp to the final room'.\n3. Turn Anti-AFK on and wait 1 hour to get the badge."
})

-- 4. Check Time Remaining Button
AdminTab:CreateButton({
    Name = "Check time remaining",
    Callback = function()
        if startTime == nil then
            Rayfield:Notify({
                Title = "Timer Not Started",
                Content = "You must use 'Tp to the final room' first!",
                Duration = 4,
                Image = "circle-alert"
            })
        else
            local timeElapsed = tick() - startTime
            local timeLeft = 3600 - timeElapsed -- 3600 seconds = 1 hour

            if timeLeft <= 0 then
                Rayfield:Notify({
                    Title = "Time Up!",
                    Content = "The hour is up! You should have the badge.",
                    Duration = 5,
                    Image = "hourglass"
                })
            else
                local minutes = math.floor(timeLeft / 60)
                local seconds = math.floor(timeLeft % 60)
                Rayfield:Notify({
                    Title = "Time Remaining",
                    Content = string.format("Remaining: %d minutes and %d seconds", minutes, seconds),
                    Duration = 5,
                    Image = "hourglass"
                })
            end
        end
    end,
})
