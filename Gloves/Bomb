-- BOMB GLOVE TAB SCRIPT
local Stewfield = getgenv().sbstew_Stewfield
local Window = getgenv().sbstew_Window

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local Grass = Workspace.Arena["main island"].Grass
local ZeroPosition = Grass.Position
local BotSpeed = 22
local RoamRange = 120
local MaxLockDistance = 80
local AcceptableDistance = 15
local TargetGlove = "Warp"

local SlapRemote = ReplicatedStorage:WaitForChild("WarpHt")
local AbilityRemote = ReplicatedStorage:WaitForChild("WLOC")
local SlapAnimation = ReplicatedStorage.Slap

local LockedTarget = nil
local SlapCooldown = false
local LocalHumanoid = nil
local Animation = nil
local HasSlapped = false

local BombTab = Window:CreateTab("Bomb Glove", "Bomb")
BombTab:CreateLabel("Bomb Glove Obtainment (Needs Warp)")

local function CharacterLoaded(Character)
    local Humanoid = Character:WaitForChild("Humanoid", 10)
    LocalHumanoid = Humanoid
    Animation = (Humanoid:FindFirstChild("Animator") or Humanoid):LoadAnimation(SlapAnimation)
    Humanoid.AutomaticScalingEnabled = false
    Humanoid.HipHeight = 0.1

    local Root = Character:WaitForChild("HumanoidRootPart")
    local Support = Root:FindFirstChild("Bot Support") or Instance.new("BodyPosition")
    Support.Position = ZeroPosition
    Support.MaxForce = Vector3.new(200, 0, 200)
    Support.Name = "Bot Support"
    Support.Parent = Root
    HasSlapped = false
end

local function GetTarget(LocalHumanoid)
    for _, v in ipairs(Players:GetPlayers()) do
        local Character = v.Character
        if v ~= LocalPlayer and Character and not LocalPlayer:IsFriendsWith(v.UserId) then
            local Humanoid = Character:FindFirstChildWhichIsA("Humanoid")
            if Humanoid and Humanoid.Health > 0 then
                local Root = Humanoid.RootPart
                if Root then
                    local Distance = (LocalHumanoid.RootPart.Position - Root.Position).Magnitude
                    local InMap = (Root.Position - ZeroPosition).Magnitude < RoamRange
                    
                    -- Advanced Filters
                    local InLobby = Character:FindFirstChild("InLobby")
                    local Rock = Character:FindFirstChild("rock")
                    local Reverse = Character:FindFirstChild("Reversed")
                    local Skull = Character:FindFirstChild("Skull")
                    local Counter = Character:FindFirstChild("Counterd")
                    local Steve = Character:FindFirstChild("stevebody")
                    local Visible = Character:FindFirstChild("CarKeysCar") or (Character:FindFirstChild("Head") or Character:FindFirstChildWhichIsA("BasePart")).Transparency == 0
                    local BuddyBox = Character.Head:FindFirstChild("BuddyBox")
                    local Ragdolled = Character:FindFirstChild("FakePart Right Arm")

                    local Approved = (InMap and Distance <= MaxLockDistance and not Rock and not Reverse and not Steve and not Skull and Visible and not BuddyBox and not Ragdolled and not InLobby and not Counter)

                    if Approved then
                        return Root, Distance
                    end
                end
            end
        end
    end
    return nil, 512
end

local function StartBombLoop()
    task.spawn(function()
        while getgenv().BSF_Bomb do
            local Character = LocalPlayer.Character
            if LocalHumanoid and LocalHumanoid.Parent and Character then
                
                -- 1. CHECK LOBBY / EQUIP
                if Character:FindFirstChild("InLobby") then
                    if LocalPlayer.leaderstats.Glove.Value ~= TargetGlove then
                        local GloveObj = Workspace.Lobby:WaitForChild(TargetGlove, 2)
                        if GloveObj then
                            fireclickdetector(GloveObj:FindFirstChildOfClass("ClickDetector"))
                        end
                    else
                        LocalHumanoid:MoveTo(Workspace.Lobby.Teleport1.Position)
                    end
                
                -- 2. ARENA LOGIC
                elseif not HasSlapped then
                    local TargetRoot, Distance = GetTarget(LocalHumanoid)
                    if TargetRoot then
                        LocalHumanoid:MoveTo(TargetRoot.Position)
                        if Distance < AcceptableDistance and not SlapCooldown then
                            SlapCooldown = true
                            Animation:Play()
                            SlapRemote:FireServer(TargetRoot)
                            HasSlapped = true
                            task.delay(0.6, function() SlapCooldown = false end)
                        end
                    end
                
                -- 3. ABILITY & BARRIER
                else
                    task.wait(2) -- Wait 2 seconds after slap
                    
                    -- Fire Ability
                    AbilityRemote:FireServer({})
                    
                    task.wait(0.1) -- Wait 0.1 seconds
                    
                    -- Instant Death Barrier Touch
                    local leg = Character:FindFirstChild("Left Leg") or LocalHumanoid.RootPart
                    local barrier = Workspace:FindFirstChild("DEATHBARRIER") or Workspace:FindFirstChild("dedBarrier")
                    
                    if barrier then
                        firetouchinterest(leg, barrier, 0)
                        task.wait(0.05)
                        firetouchinterest(leg, barrier, 1)
                    end
                    
                    getgenv().BSF_Bomb = false -- Stop script
                end

                -- Maintain Speed
                if LocalHumanoid.RootPart then
                    LocalHumanoid.WalkSpeed = BotSpeed
                end
            end
            RunService.RenderStepped:Wait()
        end
    end)
end

BombTab:CreateButton({
    Name = "Get Bomb",
    Callback = function()
        local unlocked = LocalPlayer:FindFirstChild("_unlockedGloves")
        local hasWarp = unlocked and unlocked:FindFirstChild("Warp") and unlocked.Warp.Value == true

        if not hasWarp then
            Stewfield:Notify({
                Title = "Missing Requirement",
                Content = "You need the Warp glove unlocked first!",
                Duration = 3,
                Image = "lock"
            })
            return
        end

        getgenv().BSF_Bomb = true
        if LocalPlayer.Character then
            CharacterLoaded(LocalPlayer.Character)
            StartBombLoop()
        end
    end,
})

BombTab:CreateParagraph({
    Title = "Instructions",
    Content = "1. Press 'Get Bomb' to run the bot once, if you don't have Warp the bot won't run."
})

return BombTab
