-- BOMB GLOVE TAB SCRIPT
local Stewfield = getgenv().sbstew_Stewfield
local Window = getgenv().sbstew_Window

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local Grass = Workspace.Arena["main island"].Grass
local ZeroPosition = Grass.Position
local BotSpeed = 21
local RoamRange = 120
local MaxLockDistance = 80
local AcceptableDistance = 15
local TargetGlove = "Warp"

local SlapRemote = ReplicatedStorage:WaitForChild("WarpHt")
local AbilityRemote = ReplicatedStorage:WaitForChild("WLOC")
local SlapAnimation = ReplicatedStorage.Slap
local Reset = LocalPlayer.Reset

local LockedTarget = nil
local SlapCooldown = false
local LocalHumanoid = nil
local Animation = nil
local HasSlapped = false

local BombTab = Window:CreateTab("Bomb Glove", "Bomb")
BombTab:CreateLabel("Bomb Glove Obtainment (Needs Warp)")

local function ReturnValidVector3Unit(Vector)
    if Vector.Magnitude == 0 then return Vector3.zero end
    return Vector.Unit
end

local function CharacterLoaded(Character)
    local Humanoid = Character:WaitForChild("Humanoid", 10)
    LocalHumanoid = Humanoid
    Animation = (Humanoid:FindFirstChild("Animator") or Humanoid):LoadAnimation(SlapAnimation)
    Humanoid.AutomaticScalingEnabled = false
    Humanoid.HipHeight = 0.1

    local Support = Humanoid.RootPart:FindFirstChild("Bot Support") or Instance.new("BodyPosition")
    Support.Position = ZeroPosition
    Support.MaxForce = Vector3.new(200, 0, 200)
    Support.Name = "Bot Support"
    Support.Parent = Humanoid.RootPart
    HasSlapped = false
end

local function GetTarget()
    if LockedTarget then
        local Character = LockedTarget.Character
        local IsValid = LockedTarget.Parent == Players and Character and Character:FindFirstChild("Humanoid") and Character.Humanoid.Health > 0
        if not IsValid then LockedTarget = nil return nil, 512 end
        local Root = Character.Humanoid.RootPart
        return LockedTarget, (LocalHumanoid.RootPart.Position - Root.Position).Magnitude
    end

    for _, v in ipairs(Players:GetPlayers()) do
        local Character = v.Character
        if v ~= LocalPlayer and Character then
            local Humanoid = Character:FindFirstChildWhichIsA("Humanoid")
            if Humanoid and Humanoid.Health > 0 and Humanoid.RootPart then
                local Distance = (LocalHumanoid.RootPart.Position - Humanoid.RootPart.Position).Magnitude
                if Distance <= MaxLockDistance and not Character:FindFirstChild("InLobby") then
                    LockedTarget = v
                    return v, Distance
                end
            end
        end
    end
    return nil, 512
end

local function StartBombLoop()
    task.spawn(function()
        while getgenv().BSF_Bomb do
            local Character = LocalPlayer.Character
            if LocalHumanoid and LocalHumanoid.RootPart and Character then
                
                -- 1. CHECK LOBBY / EQUIP
                if Character:FindFirstChild("InLobby") then
                    if LocalPlayer.leaderstats.Glove.Value ~= TargetGlove then
                        local GloveObj = Workspace.Lobby:WaitForChild(TargetGlove, 2)
                        if GloveObj then
                            fireclickdetector(GloveObj:FindFirstChildOfClass("ClickDetector"))
                        end
                    else
                        LocalHumanoid:MoveTo(Workspace.Lobby.Teleport1.Position)
                    end
                
                -- 2. ARENA LOGIC
                elseif not HasSlapped then
                    local TargetPlayer, Distance = GetTarget()
                    if TargetPlayer and TargetPlayer.Character then
                        local TargetRoot = TargetPlayer.Character:FindFirstChildWhichIsA("Humanoid").RootPart
                        LocalHumanoid:MoveTo(TargetRoot.Position)

                        if Distance < AcceptableDistance and not SlapCooldown then
                            SlapCooldown = true
                            Animation:Play()
                            -- Using the Target's RootPart as the "Torso" argument
                            SlapRemote:FireServer(TargetRoot)
                            HasSlapped = true
                            task.delay(0.6, function() SlapCooldown = false end)
                        end
                    end
                else
                    -- 3. WALK OFF MAP
                    LocalHumanoid:MoveTo(Vector3.new(ZeroPosition.X + RoamRange + 20, ZeroPosition.Y, ZeroPosition.Z))
                    
                    -- 4. CHECK FOR VOID/BARRIER
                    local RootPos = LocalHumanoid.RootPart.Position
                    if RootPos.Y < 10 then 
                        AbilityRemote:FireServer({}) 
                        task.wait(0.5)
                        getgenv().BSF_Bomb = false 
                    end
                end

                -- Maintain Speed
                if LocalHumanoid.RootPart then
                    local Speed = BotSpeed * 2 - math.clamp(LocalHumanoid.RootPart.AssemblyLinearVelocity.Magnitude, 0, BotSpeed)
                    LocalHumanoid.WalkSpeed = Speed
                end
            end
            RunService.RenderStepped:Wait()
        end
    end)
end

BombTab:CreateButton({
    Name = "Get Bomb",
    Callback = function()
        local unlocked = LocalPlayer:FindFirstChild("_unlockedGloves")
        local hasWarp = unlocked and unlocked:FindFirstChild("Warp") and unlocked.Warp.Value == true

        if not hasWarp then
            Stewfield:Notify({
                Title = "Missing Requirement",
                Content = "You need the Warp glove unlocked first!",
                Duration = 3,
                Image = "lock"
            })
            return
        end

        getgenv().BSF_Bomb = true
        if LocalPlayer.Character then
            CharacterLoaded(LocalPlayer.Character)
            StartBombLoop()
        end
    end,
})

BombTab:CreateParagraph({
    Title = "Instructions",
    Content = "1. Press 'Get Bomb' to run the bot once, if you don't have Warp the bot won't run.\n2. The bot will automatically equip Warp, enter the arena, slap someone, and walk off the edge.\n3. It will fire the ability when reaching the barrier to attempt the badge unlock.\n4. The bot is basic so it may take a few tries."
})

return BombTab
