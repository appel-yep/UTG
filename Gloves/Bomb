-- BOMB GLOVE TAB SCRIPT
local Stewfield = getgenv().sbstew_Stewfield
local Window = getgenv().sbstew_Window
local Places = getgenv().sbstew_Places

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Create Tab
local BombTab = Window:CreateTab("Bomb Glove", "bomb")
BombTab:CreateLabel("Bomb Glove Obtainment")

BombTab:CreateButton({
    Name = "Get Bomb",
    Callback = function()
        -- Slap Check logic
        local stats = LocalPlayer:FindFirstChild("leaderstats")
        local slaps = (stats and stats:FindFirstChild("Slaps")) and stats.Slaps.Value or 0
        
        if slaps < 350 then
            Stewfield:Notify({
                Title = "Locked Glove",
                Content = "You need 350 Slaps to use Swapper! (You have: " .. slaps .. ")",
                Duration = 3,
                Image = "lock",
            })
            return
        end

        if Places["Lobby"] then
            local Character = game:GetService("Players").LocalPlayer.Character
            local HRP = Character:WaitForChild("HumanoidRootPart")
            local Humanoid = Character:WaitForChild("Humanoid")

            -- 1. Reset
            firetouchinterest(Character:WaitForChild("Right Leg"), workspace.DEATHBARRIER, 0)
            task.wait(0.1)
            firetouchinterest(Character:WaitForChild("Right Leg"), workspace.DEATHBARRIER, 1)
            
            -- Wait for respawn
            task.wait(3.5)
            Character = game:GetService("Players").LocalPlayer.Character
            HRP = Character:WaitForChild("HumanoidRootPart")
            
            -- 2. Equips Swapper
            fireclickdetector(workspace.Lobby.Swapper.ClickDetector)
            task.wait(0.5)

            -- 3. Portal Touch Interest
            firetouchinterest(Character:WaitForChild("Left Arm"), workspace.Lobby.Teleport1, 0)
            task.wait(0.1)
            firetouchinterest(Character:WaitForChild("Left Arm"), workspace.Lobby.Teleport1, 1)
            
            -- 4. Teleport to Coordinates
            task.wait(0.5)
            local location = CFrame.new(-312.479736, -3.12254548, -4.81134987)
            Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            task.wait(0.1)
            HRP.CFrame = location
            
            -- 5. Use Swapper Ability (SLOC)
            task.wait(0.5)
            game:GetService("ReplicatedStorage"):WaitForChild("SLOC"):FireServer()

            Stewfield:Notify({
                Title = "Success",
                Content = "Process Complete! Check for badge.",
                Duration = 4,
                Image = "check-circle",
            })
        else
            Stewfield:Notify({
                Title = "Wrong Game",
                Content = "You must be in the Slap Battles Lobby to use this.",
                Duration = 4,
                Image = "circle-alert",
            })
        end
    end,
})

BombTab:CreateParagraph({
    Title = "Instructions",
    Content = "Press 'Get Bomb!' and wait for the script to automate the process. Ensure you have the Swapper glove unlocked before starting."
})

return BombTab
